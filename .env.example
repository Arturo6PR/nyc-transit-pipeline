# Part 1: Copy this file to .env (do not commit .env)
# Part 2: Fill in real values locally

# MTA API
MTA_API_KEY=PUT_YOUR_KEY_HERE

# Base URL for MTA GTFS-Realtime feeds
MTA_BASE_URL=https://api-endpoint.mta.info/Dataservice/mtagtfsfeeds

# Comma-separated list of feed paths
# Examples:
# nyct/gtfs-ace
# nyct/gtfs-ace,nyct/gtfs-g,nyct/gtfs-l
MTA_FEEDS=nyct/gtfs-ace

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nyc_transit
DB_USER=postgres
DB_PASSWORD=postgres

# How often the ingestion pipeline runs (in seconds)
# 3600 = once per hour, 1800 = every 30 minutes
INGEST_INTERVAL_SECONDS=3600